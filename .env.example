# ============================================
# Google Gemini API Configuration
# ============================================
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Gemini model to use (options: gemini-1.5-pro, gemini-1.5-flash, gemini-pro)
GEMINI_MODEL=gemini-1.5-pro

# Temperature for generation (0.0 to 1.0)
GEMINI_TEMPERATURE=0.7

# Maximum tokens (optional, leave empty for default)
# GEMINI_MAX_TOKENS=2048

# ============================================
# GCP Configuration (for deployment)
# ============================================
# Your GCP Project ID
GCP_PROJECT_ID=your-gcp-project-id

# Your GCP Project Name (display name)
GCP_PROJECT_NAME=your-gcp-project-name

# Service name for deployment
GCP_SERVICE_NAME=personal-ai-system

# GCP Region (e.g., us-central1, europe-west1, asia-east1)
GCP_REGION=us-central1

# ============================================
# Storage Configuration (optional)
# ============================================
# Base directory for data storage
STORAGE_BASE_DIR=data

# ============================================
# Application Configuration (optional)
# ============================================
# Enable debug mode (true/false)
DEBUG=false
